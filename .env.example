SECRET_KEY=
DJANGO_ENV=development
DEBUG=False
ALLOWED_HOSTS=127.0.0.1,localhost

# Local development may omit DATABASE_URL; production must use PostgreSQL.
DATABASE_URL=
REQUIRE_POSTGRES=False

CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

CSRF_TRUSTED_ORIGINS=

# OAuth credentials (create these in Google Cloud Console and LINE Developers)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
LINE_CHANNEL_ID=
LINE_CHANNEL_SECRET=

# System audit logs
AUDIT_LOG_RETENTION_DAYS=180

# Cloudflare Tunnel / production security
TRUST_CLOUDFLARE_PROXY=False
SECURE_SSL_REDIRECT=False
SESSION_COOKIE_SECURE=False
CSRF_COOKIE_SECURE=False
SECURE_HSTS_SECONDS=0
SECURE_HSTS_INCLUDE_SUBDOMAINS=False
SECURE_HSTS_PRELOAD=False
