# Use with: DJANGO_ENV_FILE=.env.development .venv/bin/python manage.py runserver
SECRET_KEY=replace-with-a-local-development-secret
DJANGO_ENV=development
DEBUG=True
ALLOWED_HOSTS=127.0.0.1,localhost,rental-management.dotwebsite.cc
CSRF_TRUSTED_ORIGINS=
SESSION_COOKIE_NAME=dianwsu_sessionid
# Leave empty locally. Only production shares sessions across *.dotwebsite.cc.
SESSION_COOKIE_DOMAIN=

# Empty DATABASE_URL selects the local SQLite file (db.sqlite3).
DATABASE_URL=
REQUIRE_POSTGRES=False

# Add local OAuth credentials only if you also register the localhost callback
# URLs with Google and LINE. Do not copy production secrets into this file.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
LINE_CHANNEL_ID=
LINE_CHANNEL_SECRET=

SECURE_SSL_REDIRECT=False
SESSION_COOKIE_SECURE=False
CSRF_COOKIE_SECURE=False
SECURE_HSTS_SECONDS=0
