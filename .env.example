SECRET_KEY=
DJANGO_ENV=development
DEBUG=False
ALLOWED_HOSTS=127.0.0.1,localhost
# The hostname used by Docker's internal web health check.
HEALTHCHECK_HOST=localhost

# Local development may omit DATABASE_URL; Docker production uses the internal
# hostname `db` and the same values as POSTGRES_* below.
DATABASE_URL=
REQUIRE_POSTGRES=False

POSTGRES_DB=dianwsu
POSTGRES_USER=dianwsu
POSTGRES_PASSWORD=CHANGE_ME

CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

CSRF_TRUSTED_ORIGINS=

# OAuth credentials (create these in Google Cloud Console and LINE Developers)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
LINE_CHANNEL_ID=
LINE_CHANNEL_SECRET=

# System audit logs
AUDIT_LOG_RETENTION_DAYS=180

# Cloudflare Tunnel / production security
TRUST_CLOUDFLARE_PROXY=False
SECURE_SSL_REDIRECT=False
SESSION_COOKIE_SECURE=False
CSRF_COOKIE_SECURE=False
SECURE_HSTS_SECONDS=0
SECURE_HSTS_INCLUDE_SUBDOMAINS=False
SECURE_HSTS_PRELOAD=False

# Copy this from Cloudflare Dashboard > Networking > Tunnels. Never commit it.
CLOUDFLARE_TUNNEL_TOKEN_ACTIVE=
